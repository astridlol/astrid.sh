---
import Projects from '../components/Projects.astro';
import Links from '../components/Links.astro';

type AgeResponse = {
  age: number;
  nextBirthday: string;
};

const ageResponse = await fetch(
  'https://age.astrid.sh/11/19/03'
).then(async (response) => {
  return (await response.json()) as AgeResponse;
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>astrid &lt;3</title>
  </head>
  <body class="h-min-screen bg-black font-mono">
    <div class="m-4 flex items-center justify-between">
      <div class="text-2xl font-bold text-pink-200 tracking-[3px]">
        [<span class="text-xl">astrid</span>]
      </div>
      <div class="flex">
        <Links/>
      </div>
    </div>

    <div class="flex items-center justify-center mt-[10rem]">
      <div class="text-center text-white">
        <h1 class="text-4xl font-bold mb-4">hii! o/</h1>
        <p class="text-xl overflow-hidden">astrid | she/her | {ageResponse.age}</p>
        <div class="flex items-center justify-center mt-4">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M3.00977 5.83789C3.00977 5.28561 3.45748 4.83789 4.00977 4.83789H20C20.5523 4.83789 21 5.28561 21 5.83789V17.1621C21 18.2667 20.1046 19.1621 19 19.1621H5C3.89543 19.1621 3 18.2667 3 17.1621V6.16211C3 6.11449 3.00333 6.06765 3.00977 6.0218V5.83789ZM5 8.06165V17.1621H19V8.06199L14.1215 12.9405C12.9499 14.1121 11.0504 14.1121 9.87885 12.9405L5 8.06165ZM6.57232 6.80554H17.428L12.7073 11.5263C12.3168 11.9168 11.6836 11.9168 11.2931 11.5263L6.57232 6.80554Z"
              fill="currentColor"
            />
          </svg>
          <a href="mailto:me@astrid.sh" class="ml-2 underline">me@astrid.sh</a>
        </div>
        <br />
        <br />
        <p class="text-lg overflow-hidden">some projects of mine:</p>
        <section
          class="grid grid-cols-1 gap-4 auto-cols-max sm:grid-cols-2 sm:gap-3 mt-4"
        >
          <Projects />
        </section>
      </div>
    </div>
  </body>
</html>
